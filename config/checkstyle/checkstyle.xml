<?xml version="1.0"?>
<!DOCTYPE module PUBLIC
        "-//Checkstyle//DTD Checkstyle Configuration 1.3//EN"
        "https://checkstyle.org/dtds/configuration_1_3.dtd">
<module name="Checker">
    <module name="TreeWalker">
        <module name="AvoidStarImport"/>
    </module>
    <module name="RegexpSingleline">
        <property name="format" value="^import\s+(org\.springframework|com\.openai|com\.anthropic|dev\.langchain4j|com\.archdox|com\.fasterxml\.jackson)\."/>
        <property name="message" value="Forbidden import in flower-ai-harness-core."/>
    </module>
</module>
